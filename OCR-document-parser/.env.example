# App
OCR_APP_NAME=OCR Document Parser

# Storage and DB
OCR_DATABASE_URL=postgresql+psycopg://ocr_user:STRONG_PASSWORD@postgres:5432/ocr_db
OCR_STORAGE_DIR=data/documents

# MLflow (optional)
OCR_MLFLOW_TRACKING_URI=http://mlflow:5000
OCR_MLFLOW_EXPERIMENT_NAME=ocr-pipeline
OCR_MLFLOW_EXPERIMENT_ARTIFACT_LOCATION=mlflow-artifacts:/ocr-pipeline
OCR_MLFLOW_ASYNC_LOGGING=true
OCR_MLFLOW_ASYNC_QUEUE_SIZE=1000
OCR_MLFLOW_ASYNC_RETRIES=3
OCR_MLFLOW_ASYNC_RETRY_BACKOFF_SECONDS=0.5
OCR_MLFLOW_ASYNC_ENQUEUE_TIMEOUT_SECONDS=1.0

# OpenAI-compatible providers.
# Which provider/model is used for each step is configured in YAML.

# OpenAI
# OCR_OPENAI_API_KEY=sk-...
OCR_OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter
# OCR_OPENROUTER_API_KEY=sk-or-...
OCR_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Global fallback models used only when fallback_models
# are not specified in YAML config.
OCR_LLM_DEFAULT_FALLBACK_MODELS=gpt-4.1-mini,gpt-4o-mini,gpt-4.1
OCR_OPENAI_TIMEOUT_SECONDS=180.0

# Async ingest queue (RabbitMQ)
OCR_RABBITMQ_URL=amqp://ocr_user:RABBITMQ_PASSWORD@rabbitmq:5672/%2F
OCR_RABBITMQ_INGEST_QUEUE=ocr.ingest
OCR_WORKER_MAX_RETRIES=3

# Structured logs (JSON)
OCR_LOG_LEVEL=INFO
OCR_LOG_FILE_PATH=logs/app.json.log

# Движок OCR: tesseract, docling или deepseek
OCR_ENGINE=tesseract

# Настройки удаленного DeepSeek OCR через Ollama
OCR_OLLAMA_OCR_URL=https://mainwgpu.devbpm.ru/ollama/api/chat
OCR_OLLAMA_OCR_MODEL=deepseek-ocr:latest
OCR_OLLAMA_OCR_TOKEN=your_token_here
# Таймаут (сек) на один запрос к DeepSeek OCR. Увеличен для сложных многостраничных документов.
OCR_DEEPSEEK_TIMEOUT_SECONDS=500.0
# Количество retries на одну страницу при ошибке/timeout DeepSeek OCR
OCR_DEEPSEEK_PAGE_RETRIES=3

